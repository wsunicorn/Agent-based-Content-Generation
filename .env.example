# ============================================================
# Django
# ============================================================
SECRET_KEY=django-insecure-change-me-in-production-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000
SECURE_SSL_REDIRECT=False

# Optional simple password gate for public demo deployments.
APP_BASIC_AUTH_ENABLED=False
APP_BASIC_AUTH_USERNAME=admin
APP_BASIC_AUTH_PASSWORD=
APP_BASIC_AUTH_EXEMPT_PATHS=/api/health/,/static/,/media/

# ============================================================
# Database (PostgreSQL)
# ============================================================
DATABASE_URL=postgres://content_user:content_pass@localhost:5433/content_pipeline

# ============================================================
# Redis (Celery broker + Django Channels)
# ============================================================
REDIS_URL=redis://localhost:6379/0
CACHE_URL=redis://localhost:6379/1
USE_INMEMORY_CHANNEL_LAYER=False
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=True

# ============================================================
# LLM routing
# ============================================================
LLM_MODE=balanced
LLM_PROVIDER=hybrid
LOCAL_LLM_PROVIDER=ollama
STRUCTURED_LLM_PROVIDER=ollama
LOCAL_LLM_AGENTS=research,outline,writer,section_writer,editor,fact_checker,seo,qa
LLM_AGENT_PROVIDERS=research=ollama,outline=ollama,writer=ollama,section_writer=ollama,editor=ollama,fact_checker=ollama,seo=ollama,qa=ollama
LLM_AGENT_MODELS=research=qwen3:8b,outline=qwen2.5:7b,writer=qwen3:8b,section_writer=qwen3:8b,editor=qwen3:8b,fact_checker=qwen3:8b,seo=qwen2.5:7b,qa=qwen3:8b
GEMINI_AGENT_MODELS=
LLM_FALLBACK_TO_GEMINI=True
LOCAL_LLM_REQUEST_DELAY=0
LOCAL_LLM_TIMEOUT=180

# ============================================================
# Google Gemini (free tier — 10 RPM, 250 RPD)
# Get key: https://aistudio.google.com/app/apikey
# ============================================================
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_REQUEST_DELAY=6.5
GEMINI_DAILY_LIMIT=250
GEMINI_DAILY_WARN_AT=200

# ============================================================
# Local LLMs
# Ollama: https://ollama.com
# LM Studio exposes OpenAI-compatible API at http://localhost:1234/v1
# ============================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_THINK=False
OLLAMA_FAST_MODEL=qwen2.5:3b
OLLAMA_REASONING_MODEL=qwen3:8b
OLLAMA_STRUCTURED_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text-v2-moe
OLLAMA_VISION_MODEL=gemma3:4b
OLLAMA_REQUIRED_MODELS=qwen2.5:7b,qwen3:8b,nomic-embed-text-v2-moe,gemma3:4b
MAX_PARALLEL_WRITERS=2
PIPELINE_QUALITY_MODE=standard
MAX_PIPELINE_REVISIONS=2
MAX_AGENT_RETRIES=1
LANGGRAPH_RECURSION_LIMIT=80
FACT_CHECK_MODE=adaptive
FACT_CHECK_MAX_CLAIMS=6
FACT_CHECK_SKIP_SOFT_CONTENT=True
FAST_MODE_WEB_SEARCH=True
FAST_MODE_LLM_QA=True
FAST_MODE_LLM_SEO=True
RESEARCH_MAX_SOURCES=4
RESEARCH_CACHE_TTL=86400
SCRAPE_CACHE_TTL=604800
OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1
OPENAI_COMPATIBLE_MODEL=local-model
OPENAI_COMPATIBLE_API_KEY=

# ============================================================
# Tavily Search API (web search for Research Agent)
# Get key: https://tavily.com
# ============================================================
ENABLE_WEB_SEARCH=True
TAVILY_API_KEY=your-tavily-api-key-here
